# Copy this file to `.env` and fill in values. `.env` is gitignored.

# ClickUp personal API token — Settings > Apps > API Token
CLICKUP_TOKEN=your_clickup_token_here

# Path to your AryanOS/Obsidian vault (optional — defaults to C:/Users/<you>/Desktop/AryanOS)
# VAULT_PATH=C:/Users/you/Desktop/AryanOS
